# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and should never be committed.

# === Google OAuth 2.0 ===
# Create credentials at https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://your-production-url/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Match the redirect URI registered in Google Cloud Console.
# Use http://localhost:3000/api/auth/callback/google for local dev.
# Use https://<your-domain>/api/auth/callback/google in production.
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# === Google Calendar ===
# The calendar ID where reading sessions will be logged.
# Create a dedicated calendar at https://calendar.google.com, then go to
# Settings → "Integrate calendar" → copy "Calendar ID".
GOOGLE_CALENDAR_ID=

# === Session encryption ===
# 32-byte random hex used by iron-session to encrypt cookie payloads.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be the same across deployments — rotating it invalidates all sessions.
SESSION_SECRET=

# === Supabase ===
# Project URL: https://<project-ref>.supabase.co
# Service role key: dashboard → Project Settings → API → service_role
# SERVICE ROLE BYPASSES RLS — server-only. Never expose to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
